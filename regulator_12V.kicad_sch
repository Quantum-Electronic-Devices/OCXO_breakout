		(uuid "d21cc04e-b3b8-4075-a035-4dbf33fcbd88")
	)
	(text "I_lim = I_out / 500\nThe shutdown threshold is 0.3 V\n=> I_lim = 1 mA * 150 kΩ / R_I_lim\nWe do not use this feature, because we will\nregulate the current later (and better)."
		(exclude_from_sim no)
