			)
			(justify left bottom)
		)
		(uuid "197a9a4a-6d2f-4b4d-aca6-8d6abf8f000d")
	)
	(text "We do not really care about the\nvoltage drop resulting from the\nballast 'resistor', because we will\nregulate the current later."
		(exclude_from_sim no)
		(at 228.6 45.72 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "224da126-b95a-4d58-acbf-b0ceb9a534a8")
	)
	(text "Vout = (100 µA * N) * Rset"
		(exclude_from_sim no)
		(at 95.504 74.422 0)
		(effects
			(font
